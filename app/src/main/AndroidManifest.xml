<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Networking -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Persistent progress notification (runtime-requested on API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service that keeps the download alive when minimized / screen off -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Hold a partial wake lock so the OS does not suspend the transfer with the screen off -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Pre-scoped-storage: writing finished media into the public Movies/Pictures/Music dirs.
         On API 29+ we use MediaStore (RELATIVE_PATH), which needs no permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Android TV support: run on leanback devices without requiring a touchscreen. -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".YtPluckerApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:banner="@drawable/tv_banner"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:extractNativeLibs="true"
        android:theme="@style/Theme.YtPlucker">

        <!-- Sentry is initialized manually in YtPluckerApp with the BuildConfig DSN.
             Without this, SentryInitProvider auto-inits at process start and throws
             "DSN is required" (crashing before Application.onCreate) since no
             io.sentry.dsn meta-data exists in this manifest. -->
        <meta-data
            android:name="io.sentry.auto-init"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.YtPlucker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- Show on the Android TV home screen too. -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <!-- Appear in the system share sheet: YouTube / X "Share" send a text/plain URL. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
